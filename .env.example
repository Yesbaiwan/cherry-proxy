HOST=0.0.0.0
# Listen address
PORT=8000
# Local service port

# Leave empty to disable proxy-side Bearer auth.
OPENAI_API_KEY=
# OpenAI-compatible API key

CHERRY_BASE_URL=https://api.cherry-ai.com
# Cherry upstream base URL

CHERRY_MODELS=qwen-8b=qwen
# Format: display_name=upstream_parameter
# Supports comma/newline/semicolon separators
# Backward compatibility: if CHERRY_MODELS is empty, CHERRY_MODEL still works as a single-model fallback

CHERRY_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) CherryStudio/1.9.4 Chrome/146.0.7680.188 Electron/41.2.1 Safari/537.36
# Request User-Agent

CHERRY_REFERER=https://cherry-ai.com
# HTTP Referer

CHERRY_TITLE=Cherry Studio
# Application title header

REQUEST_TIMEOUT=60
# Upstream timeout in seconds

LOG_SSE_STREAM=false
# Set true to print raw SSE chunks for debugging
